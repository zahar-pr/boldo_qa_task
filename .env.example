# Base URL тестируемого приложения
BASE_URL=https://app.plane.so

# Email тестового аккаунта (реальный, уже зарегистрированный в Plane)
# Plane НЕ использует пароли — логин через OTP код на email
PLANE_EMAIL=your-test-email@example.com

# Workspace slug (видно в URL после логина: app.plane.so/<slug>/projects)
PLANE_WORKSPACE_SLUG=your-workspace-slug

# --- Mail.tm credentials (для автоматического чтения OTP кода) ---
# Заполним на этапе 4, сейчас можно оставить пустыми
MAIL_TM_ADDRESS=
MAIL_TM_PASSWORD=

# --- Браузер ---
HEADLESS=true
DEFAULT_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000

# --- Путь к сохранённой сессии ---
STORAGE_STATE_PATH=auth/storage_state.json